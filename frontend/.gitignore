# Ver: http://help.github.com/ignore-files/ para más sobre archivos ignorados.

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out
backend/dist/
frontend/dist/

# Node dependencies
/node_modules
backend/node_modules/
frontend/node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Lock files
package-lock.json

# API keys and secrets
.env
.env.*
!.env.example

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Local history for vscode
.history/

# Built vscode extensions
*.vsix

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# Ignore built TypeScript files
dist/**/*
backend/dist/tsconfig.tsbuildinfo
*.tsbuildinfo

# Angular specific
/.angular/cache
.angular/

# Coverage reports
coverage/
*.lcov

# Logs
logs
*.log

# Testing
.jest/
coverage/
.nyc_output/

# Miscellaneous
.sass-cache/
connect.lock
libpeerconnection.log
testem.log
typings/

# Executables / binaries
*.exe
*.msi
*.dll

# Temporary files
*.tmp
*.temp
*.swp
*.swo

# Environment / local config
.env.local
.env.development.local
.env.test.local
.env.production.local

# SQL dumps / generated files
*.sql.bak

# Ignore generated tsconfig files only
backend/dist/tsconfig.tsbuildinfo